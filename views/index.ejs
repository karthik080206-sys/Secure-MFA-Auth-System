<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Secure MFA Auth System</title>
    <link rel="stylesheet" href="/css/style.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=JetBrains+Mono&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-stone-100 text-stone-900 font-sans min-h-screen flex flex-col">
    <header class="border-b border-stone-300 p-6 bg-white">
        <div class="max-w-5xl mx-auto flex justify-between items-center">
            <h1 class="text-xl font-semibold tracking-tight">SECURE_AUTH_v1.0</h1>
            <nav class="space-x-6 text-sm font-medium uppercase tracking-wider opacity-70">
                <a href="/" class="hover:opacity-100 transition-opacity">Home</a>
                <% if (user) { %>
                    <a href="/dashboard" class="hover:opacity-100 transition-opacity">Dashboard</a>
                    <a href="/logout" class="hover:opacity-100 transition-opacity">Logout</a>
                <% } else { %>
                    <a href="/register" class="hover:opacity-100 transition-opacity">Register</a>
                    <a href="/login" class="hover:opacity-100 transition-opacity">Login</a>
                <% } %>
            </nav>
        </div>
    </header>

    <main class="flex-grow flex items-center justify-center p-6">
        <div class="max-w-md w-full bg-white border border-stone-300 rounded-2xl p-8 shadow-sm">
            <div class="mb-8">
                <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-stone-400 block mb-2">System Status: Active</span>
                <h2 class="text-3xl font-light leading-tight">Welcome to the Secure Authentication System</h2>
            </div>
            
            <p class="text-stone-600 mb-8 leading-relaxed">
                This is a structured refactor of the initial prototype. We've implemented a robust directory structure with templates and static assets.
            </p>

            <div class="mb-8 p-4 bg-stone-50 border border-stone-200 rounded-lg">
                <div class="flex items-center space-x-2">
                    <div class="w-2 h-2 bg-green-500 rounded-full"></div>
                    <span class="text-xs font-mono uppercase tracking-wider text-stone-500">System: MFA (TOTP) Active</span>
                </div>
                <p class="text-[10px] text-stone-400 mt-1">Passwords hashed with Bcrypt. Sessions secured with OTP verification.</p>
            </div>

            <div class="space-y-4">
                <% if (user) { %>
                    <a href="/dashboard" class="block w-full bg-stone-900 text-white rounded-xl py-3 font-medium hover:bg-stone-800 transition-colors text-center">
                        Go to Dashboard
                    </a>
                <% } else { %>
                    <a href="/register" class="block w-full bg-stone-900 text-white rounded-xl py-3 font-medium hover:bg-stone-800 transition-colors text-center">
                        Get Started
                    </a>
                <% } %>
                <div class="text-center">
                    <a href="#" class="text-xs font-mono uppercase tracking-widest text-stone-400 hover:text-stone-600 transition-colors">View Documentation</a>
                </div>
            </div>
        </div>
    </main>

    <footer class="p-6 border-t border-stone-300 text-[10px] font-mono uppercase tracking-widest text-stone-400 text-center">
        &copy; 2026 SECURE_AUTH_SYSTEM // ENCRYPTED_CONNECTION
    </footer>

    <script src="/js/main.js"></script>
</body>
</html>
