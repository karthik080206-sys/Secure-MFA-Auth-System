<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>App Verification - Secure MFA Auth System</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600&family=JetBrains+Mono&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="bg-stone-100 text-stone-900 font-sans min-h-screen flex flex-col">
    <header class="border-b border-stone-300 p-6 bg-white">
        <div class="max-w-5xl mx-auto flex justify-between items-center">
            <h1 class="text-xl font-semibold tracking-tight"><a href="/">SECURE_AUTH_v1.0</a></h1>
        </div>
    </header>

    <main class="flex-grow flex items-center justify-center p-6">
        <div class="max-w-md w-full bg-white border border-stone-300 rounded-2xl p-8 shadow-sm">
            <div class="mb-8">
                <span class="text-[10px] font-mono uppercase tracking-[0.2em] text-stone-400 block mb-2">Step 1 / 2</span>
                <h2 class="text-3xl font-light leading-tight">App Authenticator</h2>
                <p class="text-stone-400 text-sm mt-2">Enter the code from your Google Authenticator or similar app.</p>
            </div>

            <% if (typeof error !== 'undefined') { %>
                <div class="mb-6 p-4 bg-red-50 border border-red-200 text-red-600 text-sm rounded-xl">
                    <%= error %>
                </div>
            <% } %>
            
            <form action="/verify-app" method="POST" class="space-y-6">
                <div>
                    <label for="code" class="block text-xs font-mono uppercase tracking-widest text-stone-400 mb-2">6-Digit App Code</label>
                    <input type="text" id="code" name="code" required maxlength="6" pattern="\d{6}"
                        class="w-full bg-stone-50 border border-stone-200 rounded-xl px-4 py-3 focus:outline-none focus:border-stone-900 transition-colors text-center text-2xl tracking-[0.5em] font-mono"
                        placeholder="000000" autofocus>
                </div>

                <button type="submit" id="submitBtn" class="w-full bg-stone-900 text-white rounded-xl py-3 font-medium hover:bg-stone-800 transition-colors">
                    Verify App Code
                </button>
            </form>

            <script>
                document.querySelector('form').addEventListener('submit', function() {
                    const btn = document.getElementById('submitBtn');
                    btn.disabled = true;
                    btn.innerText = 'Verifying...';
                    btn.classList.add('opacity-50', 'cursor-not-allowed');
                });
            </script>

            <div class="mt-8 text-center">
                <p class="text-sm text-stone-400">Lost access? <a href="/login" class="text-stone-900 hover:underline">Restart Login</a></p>
            </div>
        </div>
    </main>

    <footer class="p-6 border-t border-stone-300 text-[10px] font-mono uppercase tracking-widest text-stone-400 text-center">
        &copy; 2026 SECURE_AUTH_SYSTEM // PHASE_1_COMPLETE
    </footer>
</body>
</html>
